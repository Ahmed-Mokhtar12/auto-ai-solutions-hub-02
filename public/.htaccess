# SPA fallback — let React Router handle unknown paths
RewriteEngine On
RewriteBase /
RewriteRule ^index\.html$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]

# Correct MIME types (Hostinger sometimes mislabels .mjs)
AddType application/javascript .js .mjs
AddType text/css            .css
AddType image/svg+xml       .svg
AddType font/woff2          .woff2

# Gzip compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE application/javascript text/css text/html image/svg+xml application/json
</IfModule>

# Caching
<IfModule mod_headers.c>
  <FilesMatch "^.+\.(js|mjs|css|woff2|svg|png|jpg|jpeg|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
